NODE_ENV=development
PORT=3201
MONGODB_URL=mongodb://localhost:27017/autowrx

JWT_COOKIE_NAME=token
JWT_SECRET=dev_secret_change_me
# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=30
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=30
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10
JWT_COOKIE_NAME=your-token-name
JWT_COOKIE_DOMAIN=your-domain


ADMIN_EMAILS=admin89@email.com
ADMIN_PASSWORD=789789789

CORS_ORIGINS=localhost:\d+,127\\.0\\.0\\.1:\d+

# GenAI service
# GENAI_URL=http://genai-service:8000

# Kit server — where the AAOS kit client (and the existing /kit-server proxy)
# connect to. Defaults to the public relay if left unset; point this at your
# own self-hosted Kit Manager instead if you have one (e.g. http://kit-server:3090).
# KIT_SERVER_URL=https://kit.digitalauto.tech

# AAOS bridge
# AAOS_RUST_SERVICE_URL=http://127.0.0.1:8080/config
# AAOS_OPERATION=enable_event
# AAOS_SUBSCRIBE_METHOD_ID=16
# AAOS_TTL_MS=1000
# AAOS_REQUEST_TIMEOUT_MS=10000
# Stable kit_id this backend registers under with Kit Manager. Leave blank to
# auto-generate one on first run (saved to backend/.aaos-kit-id).
 AAOS_KIT_ID=AAOS-cuttlefish
# How often (ms) to re-send the latest AAOS value to subscribed clients.
# AAOS_PUSH_INTERVAL_MS=500
