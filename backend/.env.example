NODE_ENV=development
PORT=3200
MONGODB_URL=mongodb://localhost:27010/autowrx

JWT_COOKIE_NAME=token
JWT_SECRET=dev_secret_change_me
# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=30
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=30
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10
# For production only - set the domain where cookies should be sent
JWT_COOKIE_DOMAIN=

ADMIN_EMAILS=admin89@email.com
ADMIN_PASSWORD=789789789

# CORS configuration - update for your deployment domain
# Development: Allow localhost and 127.0.0.1 on any port
# Production: Add your production domain here
CORS_ORIGINS=localhost:\d+,127\\.0\\.0\\.1:\d+

# --- Azure OpenAI (SDV Copilot) ---
# Required for the SDV Copilot tab. Without these the /v2/openai/* endpoints
# return 500 (Invalid URL) on every code-generation request.
# Endpoint format:
#   https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
